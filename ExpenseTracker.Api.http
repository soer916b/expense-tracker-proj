@host = http://localhost:5290

### Get all expenses
GET {{host}}/expenses
Accept: application/json

###

### Get expenses by category [Beer]:
GET {{host}}/expenses?category=Beer
Accept: application/json

### Blank category:
GET {{host}}/expenses?category=
Accept: application/json

GET {{host}}/expenses?category=
Accept: application/json

### Get single expense by id
GET {{host}}/expenses?sortBy=amount&sortOrder=desc
Accept: application/json

### testing sorting:


### Get expenses tests:
GET {{host}}/expenses
Accept: application/json

###
GET {{host}}/expenses?startDate=2026-03-01&endDate=2026-03-31
Accept: application/json

### Create valid expense 1
POST {{host}}/expenses
Content-Type: application/json

{
  "amount": 50.00,
  "category": "Food",
  "description": "Lunch",
  "date": "2026-03-10"
}

###

### Create valid expense 2
POST {{host}}/expenses
Content-Type: application/json

{
  "amount": 120.00,
  "category": "Transport",
  "description": "Train card",
  "date": "2026-03-15"
}

###

### Create valid expense 3 (different month)
POST {{host}}/expenses
Content-Type: application/json

{
  "amount": 300.00,
  "category": "Rent",
  "description": "April rent",
  "date": "2026-04-01"
}

###

### Create invalid expense: amount must be greater than 0
POST {{host}}/expenses
Content-Type: application/json

{
  "amount": 0,
  "category": "Food",
  "description": "Invalid amount",
  "date": "2026-03-12"
}

###

### Create invalid expense: category must not be blank
POST {{host}}/expenses
Content-Type: application/json

{
  "amount": 25.00,
  "category": "",
  "description": "Missing category",
  "date": "2026-03-12"
}

###

### Create invalid expense: description too long
POST {{host}}/expenses
Content-Type: application/json

{
  "amount": 25.00,
  "category": "Food",
  "description": "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
  "date": "2026-03-12"
}

###

### Create invalid expense: date must be set (default DateOnly)
POST {{host}}/expenses
Content-Type: application/json

{
  "amount": 25.00,
  "category": "Food",
  "description": "Default date",
  "date": "0001-01-01"
}

###

### Update existing expense with valid data
PUT {{host}}/expenses/1
Content-Type: application/json

{
  "amount": 75.00,
  "category": "Groceries",
  "description": "Updated expense",
  "date": "2026-03-20"
}

###

### Update existing expense with invalid amount
PUT {{host}}/expenses/1
Content-Type: application/json

{
  "amount": -5.00,
  "category": "Groceries",
  "description": "Invalid update",
  "date": "2026-03-20"
}

###

### Update non-existing expense
PUT {{host}}/expenses/999
Content-Type: application/json

{
  "amount": 100.00,
  "category": "Test",
  "description": "Should not exist",
  "date": "2026-03-23"
}

###

### Delete expense by id
DELETE {{host}}/expenses/4

###

### Get all expenses after delete
GET {{host}}/expenses
Accept: application/json

###

### Get monthly summary for March 2026
GET {{host}}/expenses/summary?year=2026&month=3
Accept: application/json

###

### Get monthly summary for April 2026
GET {{host}}/expenses/summary?year=2026&month=4
Accept: application/json

###

### Get monthly summary for month with no expenses
GET {{host}}/expenses/summary?year=2026&month=5
Accept: application/json

###

### Invalid summary input: negative year
GET {{host}}/expenses/summary?year=-1&month=3
Accept: application/json

###

### Invalid summary input: month = 0
GET {{host}}/expenses/summary?year=2026&month=0
Accept: application/json

###

### Invalid summary input: month = 13
GET {{host}}/expenses/summary?year=2026&month=13
Accept: application/json


### Filter by category and sort by amount ascending
GET {{host}}/expenses?category=Food&sortBy=amount

### Filter by category and sort by amount descending
GET {{host}}/expenses?category=Food&sortBy=amount&sortOrder=desc

### Filter by date interval and sort by date ascending
GET {{host}}/expenses?startDate=2026-03-01&endDate=2026-03-31&sortBy=date

### Filter by date interval and sort by date descending
GET {{host}}/expenses?startDate=2026-03-01&endDate=2026-03-31&sortBy=date&sortOrder=desc

### Filter by category and date interval, then sort by amount descending
GET {{host}}/expenses?category=Groceries&startDate=2026-03-01&endDate=2026-03-31&sortBy=amount&sortOrder=desc

### Filter by category and start date only, then sort by date
GET {{host}}/expenses?category=Transport&startDate=2026-03-01&sortBy=date

### Filter by category and end date only, then sort by amount
GET {{host}}/expenses?category=Bills&endDate=2026-03-31&sortBy=amount